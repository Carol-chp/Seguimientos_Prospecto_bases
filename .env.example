# ============================================================
# Variables de entorno — Sistema de Seguimiento de Prospectos
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commitees el .env con valores reales.
# ============================================================

# Perfil de Spring activo: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ---- Base de datos PostgreSQL ----
# Ejemplo prod: jdbc:postgresql://db.servidor.com:5432/seguimiento_prospectos
DB_URL=jdbc:postgresql://localhost:5432/seguimiento_prospectos
DB_USER=postgres
DB_PASS=changeme

# ---- JWT Secret ----
# Minimo 32 caracteres. Generar con: openssl rand -base64 48
JWT_SECRET=cambiar-por-clave-secreta-de-al-menos-32-chars-en-produccion!

# ---- CORS ----
# Origenes permitidos separados por coma.
# Dev: http://localhost:4200
# Prod: https://app.midominio.com
# TODO: reemplazar con la URL real del frontend antes del primer deploy.
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ---- Email Gmail (RF-07 resumen 9pm) ----
# Desactivado por defecto: el sistema funciona y el resumen 9pm se "salta"
# (queda registrado en /api/reportes/estado-email) hasta que se configure.
# Para ACTIVAR el envío:
#   1) La cuenta Gmail del dueño debe tener 2FA activado.
#   2) Generar una App Password en https://myaccount.google.com/apppasswords
#   3) Definir estas 3 variables y reiniciar:
# MAIL_ENABLED=true
# MAIL_USERNAME=dueno@gmail.com
# MAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Opcionales: MAIL_HOST (def smtp.gmail.com), MAIL_PORT (def 587),
#             MAIL_RESUMEN_CRON (def "0 0 21 * * *", zona America/Lima)
